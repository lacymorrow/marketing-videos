  "type": "commonjs",
  "dependencies": {
    "@react-three/fiber": "^9.5.0",
    "@remotion/bundler": "^4.0.432",
    "@remotion/cli": "^4.0.432",
    "@remotion/noise": "^4.0.432",
    "@remotion/renderer": "^4.0.432",
    "@remotion/three": "^4.0.432",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "remotion": "^4.0.432",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3"
  }
